                        </div>
                    </div>
                </div> <!-- Akhir Area Konten Kanan -->
            </div>
        </div>

    </div>

    <!-- LOGIKA APLIKASI (Vanilla JS) -->
    <script>
        // ======= KONFIGURASI =======
        // GANTI URL INI DENGAN URL DEPLOY GOOGLE APPS SCRIPT ANDA
        const GAS_URL = "https://script.google.com/macros/s/AKfycbwSmqZPjm_lJBvM4FA6NS0MkQluvqbg4g9jBfNQmTAPpxl8j6hJiGtB0dSQlQeGSLUMsA/exec"; 
        
        let currentUser = "";
        let examData = [];
        let currentQuestionIndex = 0;
        let userAnswers = {};
        let timeRemaining = 60 * 60; // 60 menit
        let timerInterval;
        let isExamActive = false;
        let cheatStatus = "Aman";
        let loginMode = "siswa";

        // ======= FUNGSI NAVIGASI UI & LOGOUT =======
        function showView(viewId) {
            // Sembunyikan semua view
            document.querySelectorAll('div[id^="view-"]').forEach(el => el.classList.add('hide'));
            // Tampilkan view tujuan
            document.getElementById(viewId).classList.remove('hide');

            // Kontrol tombol Navigasi Admin kecil di Kanan Atas
            const topNav = document.getElementById('top-admin-nav');
            if (topNav) {
                if (viewId === 'view-login') topNav.classList.remove('hide');
                else topNav.classList.add('hide');
            }
        }

        function logoutAdmin() {
            Swal.fire({
                title: 'Keluar Dashboard?',
                text: "Sesi admin Anda akan diakhiri.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Ya, Keluar!',
                cancelButtonText: 'Batal'
            }).then((result) => {
                if (result.isConfirmed) {
                    currentUser = "";
                    document.getElementById('username-admin').value = "";
                    document.getElementById('password-admin').value = "";
                    
                    showView('view-login');
                    
                    Swal.fire({ title: 'Berhasil Keluar', icon: 'success', timer: 1500, showConfirmButton: false });
                }
            });
        }

        function logoutSiswa() {
            currentUser = "";
            examData = [];
            currentQuestionIndex = 0;
            userAnswers = {};
            timeRemaining = 60 * 60;
            isExamActive = false;
            cheatStatus = "Aman";
            
            document.getElementById('username-siswa').value = "";
            document.getElementById('password-siswa').value = "";
            
            document.getElementById('cheat-alert').classList.add('hide');
            document.getElementById('final-score').classList.remove('text-red-600');
            document.getElementById('final-score').classList.add('text-indigo-600');
            
            showView('view-login');
        }

        // ======= FUNGSI LOGIN & AUTENTIKASI =======
        async function handleLogin(role) {
            let user = "";
            let pass = "";

            // Deteksi Role mana yang menekan tombol login
            if (role === 'admin') {
                user = document.getElementById('username-admin').value.trim();
                pass = document.getElementById('password-admin').value.trim();
            } else {
                user = document.getElementById('username-siswa').value.trim();
                pass = document.getElementById('password-siswa').value.trim();
            }

            if (!user || !pass) {
                Swal.fire('Error', 'Username dan Password wajib diisi!', 'warning');
                return;
            }

            // Validasi URL Dummy
            if (GAS_URL.includes("XXXXXXXXXXXX")) {
                Swal.fire('Konfigurasi URL Backend!', 'Harap ganti variabel GAS_URL di kode HTML dengan URL Web App dari Apps Script Anda.', 'warning');
                return;
            }

            // Mode Admin
            if (role === 'admin') {
                if (user.toLowerCase() === 'admin' && pass === 'hasyimoto') {
                    Swal.fire({ title: 'Login Admin Berhasil', text: 'Memuat Database CMS...', icon: 'success', allowOutsideClick: false, didOpen: () => { Swal.showLoading() }});
                    showView('view-admin');
                    fetchAdminDataAll();
                    return;
                } else {
                    Swal.fire('Akses Ditolak', 'Username atau Password Admin salah!', 'error');
                    return;
                }
            }

            // Mode Siswa
            Swal.fire({ title: 'Otentikasi...', text: 'Mengecek akun siswa...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });

            try {
                const res = await fetch(GAS_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'text/plain' },
                    body: JSON.stringify({ action: "loginSiswa", username: user, password: pass })
                });
                const data = await res.json();
                
                if (data.status === 'success') {
                    currentUser = user;
                    examData = data.data; 
                    
                    if (!examData || examData.length === 0) {
                        Swal.fire('Info', 'Belum ada soal ujian yang dibuat oleh admin.', 'info');
                        return;
                    }
                    
                    document.getElementById('student-name-display').innerText = currentUser;
                    document.getElementById('total-q-num').innerText = examData.length;
                    Swal.close();
                    showView('view-petunjuk');
                } else {
                    Swal.fire('Akses Ditolak', data.message || 'Username atau Password salah!', 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Gagal terhubung ke Server. Pastikan URL GAS benar.', 'error');
            }
        }

        // ======= FUNGSI UJIAN =======
        function startExam() {
            showView('view-ujian');
            isExamActive = true;
            renderQuestion();
            startTimer();
            initAntiCheat();
            
            // Masuk mode fullscreen di mobile jika didukung
            if (document.documentElement.requestFullscreen) {
                document.documentElement.requestFullscreen().catch((e) => console.log(e));
            }
        }

        function renderQuestion() {
            const q = examData[currentQuestionIndex];
            const container = document.getElementById('question-container');
            
            // Render Teks Bacaan (Bahasa Inggris) jika ada
            let readingHtml = '';
            if (q.readingText) {
                readingHtml = `<div class="reading-text rounded-lg shadow-inner">${q.readingText.replace(/\n/g, '<br>')}</div>`;
            }

            // Render Pilihan Ganda
            let optionsHtml = '';
            q.options.forEach((opt, idx) => {
                const isChecked = userAnswers[currentQuestionIndex] === opt ? 'checked' : '';
                optionsHtml += `
                    <div class="relative">
                        <input type="radio" name="q_option" id="opt_${idx}" value="${opt}" class="hidden" ${isChecked} onchange="saveAnswer('${opt}')">
                        <label for="opt_${idx}" class="option-label text-gray-700">
                            <span class="font-bold mr-2">${String.fromCharCode(65 + idx)}.</span> ${opt}
                        </label>
                    </div>
                `;
            });

            container.innerHTML = `
                ${readingHtml}
                <div class="mb-6">
                    <h3 class="text-xl font-bold text-gray-800 mb-4">${currentQuestionIndex + 1}. ${q.question}</h3>
                    <div class="space-y-3">
                        ${optionsHtml}
                    </div>
                </div>
            `;

            // Update Navigasi
            document.getElementById('current-q-num').innerText = currentQuestionIndex + 1;
            document.getElementById('btn-prev').classList.toggle('hide', currentQuestionIndex === 0);
            
            if (currentQuestionIndex === examData.length - 1) {
                document.getElementById('btn-next').classList.add('hide');
                document.getElementById('btn-submit').classList.remove('hide');
            } else {
                document.getElementById('btn-next').classList.remove('hide');
                document.getElementById('btn-submit').classList.add('hide');
            }
        }

        function saveAnswer(val) {
            userAnswers[currentQuestionIndex] = val;
        }

        function nextQuestion() {
            if (currentQuestionIndex < examData.length - 1) {
                currentQuestionIndex++;
                renderQuestion();
            }
        }

        function prevQuestion() {
            if (currentQuestionIndex > 0) {
                currentQuestionIndex--;
                renderQuestion();
            }
        }

        // ======= FUNGSI TIMER =======
        function startTimer() {
            timerInterval = setInterval(() => {
                if(timeRemaining <= 0) {
                    clearInterval(timerInterval);
                    autoSubmit("Waktu Habis!");
                    return;
                }
                timeRemaining--;
                let m = Math.floor(timeRemaining / 60);
                let s = timeRemaining % 60;
                document.getElementById('timer-display').innerText = `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
            }, 1000);
        }

        // ======= ANTI-CHEAT SYSTEM =======
        function initAntiCheat() {
            // 1. Deteksi Pindah Tab / Minimize
            document.addEventListener("visibilitychange", () => {
                if (document.visibilityState === 'hidden' && isExamActive) {
                    triggerCheat("Siswa meminimalkan jendela atau berpindah tab.");
                }
            });

            // 2. Deteksi Kehilangan Fokus Jendela (Split Screen/Notifikasi Ditekan)
            window.addEventListener("blur", () => {
                if (isExamActive) {
                    triggerCheat("Jendela ujian kehilangan fokus (mungkin membuka layar belah/aplikasi lain).");
                }
            });

            // 3. Mencegah Klik Kanan & Copy Paste
            document.addEventListener('contextmenu', event => event.preventDefault());
            document.addEventListener('copy', event => { event.preventDefault(); Swal.fire('Peringatan', 'Dilarang menyalin soal!', 'warning'); });
            
            // 4. Deteksi Layar Terbelah Kasar (Perubahan tinggi viewport ekstrim di mobile)
            let initialHeight = window.innerHeight;
            window.addEventListener('resize', () => {
                if(isExamActive && !document.activeElement.tagName.match(/INPUT|TEXTAREA/)) {
                    if (window.innerHeight < initialHeight * 0.7) {
                         triggerCheat("Terdeteksi membelah layar (Split-Screen).");
                    }
                }
            });
        }

        function triggerCheat(reason) {
            if (!isExamActive) return;
            cheatStatus = reason;
            Swal.fire({
                title: 'PELANGGARAN TERDETEKSI!',
                text: 'Sistem Anti-Cheat menangkap aktivitas ilegal. Ujian dihentikan otomatis!',
                icon: 'error',
                confirmButtonText: 'Tutup',
                allowOutsideClick: false
            }).then(() => {
                autoSubmit("Pelanggaran Anti-Cheat");
            });
        }

        // ======= SUBMIT & PENILAIAN =======
        function confirmSubmit() {
            Swal.fire({
                title: 'Kumpulkan Jawaban?',
                text: "Pastikan semua soal telah dijawab.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Ya, Kumpulkan',
                cancelButtonText: 'Batal'
            }).then((result) => {
                if (result.isConfirmed) autoSubmit("Selesai Normal");
            });
        }

        async function autoSubmit(reason) {
            isExamActive = false;
            clearInterval(timerInterval);
            
            // Hitung Nilai
            let correct = 0;
            examData.forEach((q, idx) => {
                if (userAnswers[idx] === q.answer) correct++;
            });
            let total = examData.length;
            let finalScore = Math.round((correct / total) * 100);

            // Validasi URL Dummy
            if (GAS_URL.includes("XXXXXXXXXXXX")) {
                Swal.fire('Ujian Selesai (Mode Offline)', 'Anda masih menggunakan URL GAS dummy. Data tidak tersimpan ke database. Nilai Anda: ' + finalScore, 'warning');
                showView('view-hasil');
                document.getElementById('final-score').innerText = finalScore;
                document.getElementById('correct-answers').innerText = correct;
                document.getElementById('total-questions-result').innerText = total;
                return;
            }

            // Tampilkan UI Loading
            Swal.fire({ title: 'Menyimpan Data...', text: 'Mengirim jawaban ke server', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

            // Payload untuk dikirim ke GAS Backend
            const payload = {
                action: "submitExam",
                namaSiswa: currentUser,
                skorBenar: correct,
                totalSoal: total,
                nilaiAkhir: finalScore,
                statusKecurangan: cheatStatus
            };

            try {
                // Kirim ke Backend menggunakan POST Plain Text (Hindari Preflight CORS)
                const res = await fetch(GAS_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'text/plain' },
                    body: JSON.stringify(payload)
                });
                const result = await res.json();
                
                if(result.status === 'success') {
                    Swal.close();
                    showView('view-hasil');
                    document.getElementById('final-score').innerText = finalScore;
                    document.getElementById('correct-answers').innerText = correct;
                    document.getElementById('total-questions-result').innerText = total;

                    if (cheatStatus !== "Aman") {
                        document.getElementById('cheat-alert').classList.remove('hide');
                        document.getElementById('cheat-reason').innerText = cheatStatus;
                        document.getElementById('final-score').classList.replace('text-indigo-600', 'text-red-600');
                    }
                }
            } catch (error) {
                Swal.fire('Error', 'Gagal menyimpan ke database. Harap lapor ke pengawas.', 'error');
            }
        }

        // ======= ADMIN DASHBOARD FUNGSI =======
        function switchAdminTab(tabId) {
            // Sembunyikan semua konten tab
            document.querySelectorAll('.admin-tab-content').forEach(el => {
                el.classList.remove('block'); el.classList.add('hidden');
            });
            
            // Reset gaya (style) semua tombol di sidebar (ke abu-abu/tidak aktif)
            document.querySelectorAll('.admin-tab-btn').forEach(el => {
                el.classList.remove('border-indigo-600', 'text-indigo-700', 'bg-indigo-50');
                el.classList.add('border-transparent', 'text-gray-500');
            });
            
            // Tampilkan konten tab yang dipilih
            document.getElementById(tabId).classList.remove('hidden');
            document.getElementById(tabId).classList.add('block');
            
            // Set gaya (style) aktif (warna biru indigo) ke tombol yang dipilih
            document.getElementById('btn-' + tabId).classList.remove('border-transparent', 'text-gray-500');
            document.getElementById('btn-' + tabId).classList.add('border-indigo-600', 'text-indigo-700', 'bg-indigo-50');
        }

        async function fetchAdminDataAll() {
            if (GAS_URL.includes("XXXXXXXXXXXX")) {
                renderAdminLaporan(null); renderAdminSiswa(null); renderAdminSoal(null);
                Swal.fire('Mode Preview', 'Anda belum memasukkan GAS_URL asli. Data database tidak bisa dimuat.', 'info');
                return;
            }

            try {
                const res = await fetch(GAS_URL + "?action=getAllAdminData");
                const data = await res.json();
                Swal.close();
                
                if(data.status === 'success') {
                    // Update Widget Statistik
                    const totalSiswa = data.siswa ? Object.keys(data.siswa).length : 0;
                    const totalSoal = data.soal ? Object.keys(data.soal).length : 0;
                    
                    let sudahUjian = 0;
                    if (data.hasil) {
                        // Gunakan Set untuk menghitung nama siswa unik (menghindari duplikasi hitungan jika 1 anak masuk 2x)
                        const uniqueStudents = new Set();
                        Object.values(data.hasil).forEach(record => {
                            if(record.namaSiswa) uniqueStudents.add(record.namaSiswa.toLowerCase().trim());
                        });
                        sudahUjian = uniqueStudents.size;
                    }

                    document.getElementById('stat-total-siswa').innerText = totalSiswa;
                    document.getElementById('stat-sudah-ujian').innerText = sudahUjian;
                    document.getElementById('stat-total-soal').innerText = totalSoal;

                    // Render Data ke Tabel
                    renderAdminLaporan(data.hasil);
                    renderAdminSiswa(data.siswa);
                    renderAdminSoal(data.soal);
                }
            } catch (error) {
                Swal.fire('Error', 'Gagal mengambil keseluruhan data dari Database.', 'error');
            }
        }

        // 1. Render Tab Laporan
        function renderAdminLaporan(records) {
            const tbody = document.getElementById('admin-table-body');
            if(!records) { tbody.innerHTML = '<tr><td colspan="6" class="text-center p-4">Belum ada data ujian masuk.</td></tr>'; return; }
            
            let html = '';
            const keys = Object.keys(records).reverse(); 
            keys.forEach(key => {
                const r = records[key];
                const isCurang = r.statusKecurangan !== "Aman";
                html += `
                    <tr class="border-b hover:bg-gray-50 transition">
                        <td class="p-3 text-sm">${r.timestamp}</td>
                        <td class="p-3 font-semibold uppercase">${r.namaSiswa}</td>
                        <td class="p-3 text-center">${r.skorBenar}</td>
                        <td class="p-3 text-center">${r.totalSoal}</td>
                        <td class="p-3 text-center font-bold text-lg ${isCurang ? 'text-red-600' : 'text-indigo-600'}">${r.nilaiAkhir}</td>
                        <td class="p-3 text-xs ${isCurang ? 'text-red-600 font-bold' : 'text-green-600'}">${r.statusKecurangan}</td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        // 2. Render Tab Kelola Siswa
        function renderAdminSiswa(students) {
            const tbody = document.getElementById('siswa-table-body');
            if(!students) { tbody.innerHTML = '<tr><td colspan="3" class="text-center p-4">Belum ada data siswa. Silakan tambah akun.</td></tr>'; return; }
            
            let html = '';
            for (let id in students) {
                html += `
                    <tr class="border-b hover:bg-gray-50">
                        <td class="p-3 font-bold text-gray-700">${students[id].username}</td>
                        <td class="p-3 text-gray-600">${students[id].password}</td>
                        <td class="p-3 text-center">
                            <button onclick="deleteData('data_siswa', '${id}')" class="bg-red-100 text-red-600 px-3 py-1 rounded hover:bg-red-600 hover:text-white transition"><i class="fas fa-trash"></i> Hapus</button>
                        </td>
                    </tr>
                `;
            }
            tbody.innerHTML = html;
        }

        async function addStudent() {
            const user = document.getElementById('new-siswa-name').value.trim();
            const pass = document.getElementById('new-siswa-pass').value.trim();
            if(!user || !pass) return Swal.fire('Error', 'Nama Username dan Password wajib diisi!', 'warning');
            
            Swal.fire({ title: 'Menyimpan Akun...', didOpen: () => Swal.showLoading() });
            await sendPostRequest({ action: 'saveStudent', username: user, password: pass });
            document.getElementById('new-siswa-name').value = '';
            document.getElementById('new-siswa-pass').value = '';
            fetchAdminDataAll();
        }

        // 3. Render Tab Bank Soal
        function renderAdminSoal(questions) {
            const container = document.getElementById('soal-list-container');
            if(!questions) { container.innerHTML = '<div class="text-center p-6 text-gray-500 border-2 rounded-lg border-dashed">Belum ada soal di Bank Soal. Tambahkan soal pertama di atas.</div>'; return; }
            
            let html = '';
            let count = 1;
            for (let id in questions) {
                const q = questions[id];
                html += `
                    <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-200 relative mb-4">
                        <div class="absolute top-4 right-4">
                            <button onclick="deleteData('bank_soal', '${id}')" class="bg-red-100 text-red-600 p-2 rounded hover:bg-red-600 hover:text-white transition" title="Hapus Soal"><i class="fas fa-trash"></i></button>
                        </div>
                        <h4 class="font-bold text-gray-800 mb-2">Soal #${count}</h4>
                        ${q.readingText ? `<div class="bg-gray-50 border-l-4 border-indigo-400 p-2 text-sm mb-3 text-gray-600 max-h-20 overflow-y-auto">${q.readingText}</div>` : ''}
                        <p class="font-semibold mb-3 text-gray-900">${q.question}</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm text-gray-600 mb-3 pl-4 list-disc">
                            <div>A. ${q.options[0]}</div>
                            <div>B. ${q.options[1]}</div>
                            <div>C. ${q.options[2]}</div>
                            <div>D. ${q.options[3]}</div>
                        </div>
                        <div class="bg-green-100 text-green-800 px-3 py-1 inline-block rounded font-bold text-xs"><i class="fas fa-check-circle"></i> Kunci: ${q.answer}</div>
                    </div>
                `;
                count++;
            }
            container.innerHTML = html;
        }

        async function addQuestion() {
            const reading = document.getElementById('new-soal-reading').value.trim();
            const question = document.getElementById('new-soal-question').value.trim();
            const optA = document.getElementById('new-soal-optA').value.trim();
            const optB = document.getElementById('new-soal-optB').value.trim();
            const optC = document.getElementById('new-soal-optC').value.trim();
            const optD = document.getElementById('new-soal-optD').value.trim();
            const ansKey = document.getElementById('new-soal-answer').value;
            
            if(!question || !optA || !optB || !optC || !optD) return Swal.fire('Error', 'Pertanyaan dan Semua Pilihan A-D Wajib diisi!', 'warning');
            
            // Konversi Pilihan (A/B/C/D) ke teks jawaban yang asli untuk validasi sistem
            let answerText = "";
            if (ansKey === "A") answerText = optA;
            if (ansKey === "B") answerText = optB;
            if (ansKey === "C") answerText = optC;
            if (ansKey === "D") answerText = optD;

            const payload = {
                action: 'saveQuestion',
                readingText: reading,
                question: question,
                options: [optA, optB, optC, optD],
                answer: answerText
            };

            Swal.fire({ title: 'Menyimpan Soal...', didOpen: () => Swal.showLoading() });
            await sendPostRequest(payload);
            
            // Reset Form
            document.getElementById('new-soal-reading').value = '';
            document.getElementById('new-soal-question').value = '';
            document.getElementById('new-soal-optA').value = '';
            document.getElementById('new-soal-optB').value = '';
            document.getElementById('new-soal-optC').value = '';
            document.getElementById('new-soal-optD').value = '';
            
            fetchAdminDataAll();
        }

        // Global Delete & Post Handler
        async function deleteData(type, id) {
            const result = await Swal.fire({ title: 'Hapus data ini?', text: "Data yang dihapus tidak bisa dikembalikan!", icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33' });
            if(result.isConfirmed) {
                Swal.fire({ title: 'Menghapus...', didOpen: () => Swal.showLoading() });
                await sendPostRequest({ action: 'deleteData', path: type, id: id });
                fetchAdminDataAll();
            }
        }

        async function sendPostRequest(payload) {
            if (GAS_URL.includes("XXXXXXXXXXXX")) {
                Swal.fire('Konfigurasi URL Backend!', 'Aksi dibatalkan. Harap ganti variabel GAS_URL di kode HTML dengan URL Web App dari Apps Script Anda.', 'warning');
                throw new Error("URL Dummy terdeteksi, fetch dihentikan.");
            }
            try {
                const response = await fetch(GAS_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'text/plain' },
                    body: JSON.stringify(payload)
                });
                if(!response.ok) throw new Error("Network response was not ok");
            } catch(e) {
                console.error("Gagal mengirim request POST", e);
                Swal.fire('Koneksi Gagal', 'Gagal menghubungi server (Fetch Failed). Pastikan URL Google Apps Script Anda benar dan perizinan akses diset ke "Anyone".', 'error');
                throw e; // Lemparkan error agar status loading Swal di fungsi pemanggil (addStudent, dll) berhenti
            }
        }
    </script>
</body>

            </div>
        </div>

        <!-- 4. VIEW HASIL (SISWA) -->
        <div id="view-hasil" class="hide glass-card rounded-2xl p-8 max-w-md mx-auto mt-10 text-center">
            <i class="fas fa-check-circle text-6xl text-green-500 mb-4"></i>
            <h2 class="text-2xl font-bold text-gray-800 mb-2">Ujian Selesai!</h2>
            <p class="text-gray-600 mb-6">Terima kasih telah mengikuti ujian.</p>
            <div class="bg-indigo-50 rounded-lg p-6 mb-4">
                <p class="text-sm text-gray-500 uppercase tracking-wide">Nilai Akhir Anda</p>
                <h1 class="text-6xl font-black text-indigo-600 my-2" id="final-score">0</h1>
                <p class="text-md font-semibold text-gray-700">Benar: <span id="correct-answers">0</span> / <span id="total-questions-result">0</span></p>
            </div>
            <div id="cheat-alert" class="hide bg-red-100 text-red-700 p-3 rounded-lg mb-4 font-bold border border-red-400">
                <i class="fas fa-exclamation-triangle"></i> Status: CURANG (<span id="cheat-reason"></span>)
            </div>
            
            <!-- Tombol Kembali ke Dashboard -->
            <button onclick="logoutSiswa()" class="mt-4 w-full bg-gray-800 hover:bg-gray-900 text-white font-bold py-3 px-4 rounded-lg transition duration-300 shadow-md">
                <i class="fas fa-home"></i> Kembali ke Halaman Utama
            </button>
        </div>

        <!-- 5. VIEW ADMIN DASHBOARD -->
        <div id="view-admin" class="hide glass-card rounded-2xl p-6 w-full mt-4">
            <!-- Header Top Admin -->
            <div class="flex flex-col md:flex-row justify-between items-center mb-6 no-print gap-4 border-b pb-4 border-gray-200">
                <h2 class="text-2xl font-bold text-gray-800"><i class="fas fa-chart-line text-indigo-600"></i> Dashboard Admin</h2>
                <div class="flex flex-wrap justify-center gap-2">
                    <button onclick="fetchAdminDataAll()" class="bg-blue-500 text-white px-4 py-2 rounded shadow hover:bg-blue-600 transition"><i class="fas fa-sync-alt"></i> Refresh</button>
                    <button onclick="window.print()" class="bg-green-600 text-white px-4 py-2 rounded shadow hover:bg-green-700 transition"><i class="fas fa-print"></i> Cetak</button>
                    <button onclick="logoutAdmin()" class="bg-red-500 text-white px-4 py-2 rounded shadow hover:bg-red-600 transition"><i class="fas fa-sign-out-alt"></i> Keluar</button>
                </div>
            </div>

            <!-- Kontainer Layout Utama (Sidebar + Konten) -->
            <div class="flex flex-col md:flex-row gap-6">
                
                <!-- Sidebar Menu Kiri -->
                <div class="w-full md:w-1/4 flex flex-col gap-2 no-print border-r-0 md:border-r border-gray-200 md:pr-4">
                    <button onclick="switchAdminTab('tab-laporan')" id="btn-tab-laporan" class="admin-tab-btn w-full text-left font-bold py-3 px-4 rounded-r-lg border-l-4 border-indigo-600 text-indigo-700 bg-indigo-50 transition-colors">
                        <i class="fas fa-file-alt w-6"></i> Laporan Ujian
                    </button>
                    <button onclick="switchAdminTab('tab-siswa')" id="btn-tab-siswa" class="admin-tab-btn w-full text-left font-bold py-3 px-4 rounded-r-lg border-l-4 border-transparent text-gray-500 hover:bg-gray-100 hover:text-indigo-600 transition-colors">
                        <i class="fas fa-users w-6"></i> Kelola Siswa
                    </button>
                    <button onclick="switchAdminTab('tab-soal')" id="btn-tab-soal" class="admin-tab-btn w-full text-left font-bold py-3 px-4 rounded-r-lg border-l-4 border-transparent text-gray-500 hover:bg-gray-100 hover:text-indigo-600 transition-colors">
                        <i class="fas fa-database w-6"></i> Bank Soal
                    </button>
                </div>
                
                <!-- Area Konten Kanan -->
                <div class="w-full md:w-3/4">
                    <!-- Tab 1: Laporan Ujian -->
                    <div id="tab-laporan" class="admin-tab-content block overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-max">
                            <thead>
                                <tr class="bg-indigo-600 text-white">
                                    <th class="p-3 rounded-tl-lg">Timestamp</th>
                                    <th class="p-3">Nama Siswa</th>
                                    <th class="p-3 text-center">Skor Benar</th>
                                    <th class="p-3 text-center">Total Soal</th>
                                    <th class="p-3 text-center">Nilai Akhir</th>
                                    <th class="p-3 rounded-tr-lg">Status Kecurangan</th>
                                </tr>
                            </thead>
                            <tbody id="admin-table-body">
                                <tr><td colspan="6" class="text-center p-4 text-gray-500">Memuat data...</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Tab 2: Kelola Siswa -->
                    <div id="tab-siswa" class="admin-tab-content hidden no-print">
                        <div class="bg-indigo-50 p-4 rounded-lg mb-6 border border-indigo-100">
                            <h3 class="font-bold text-indigo-800 mb-3"><i class="fas fa-user-plus"></i> Tambah Akun Siswa</h3>
                            <div class="flex flex-col md:flex-row gap-3">
                                <input type="text" id="new-siswa-name" placeholder="Nama / Username Siswa" class="flex-grow px-4 py-2 rounded-lg border focus:ring-2 focus:ring-indigo-500">
                                <input type="text" id="new-siswa-pass" placeholder="Password Login" class="flex-grow px-4 py-2 rounded-lg border focus:ring-2 focus:ring-indigo-500">
                                <button onclick="addStudent()" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 font-bold"><i class="fas fa-save"></i> Simpan</button>
                            </div>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse bg-white rounded-lg overflow-hidden shadow-sm">
                                <thead class="bg-gray-800 text-white">
                                    <tr><th class="p-3">Nama Siswa / Username</th><th class="p-3">Password</th><th class="p-3 text-center">Aksi</th></tr>
                                </thead>
                                <tbody id="siswa-table-body">
                                    <tr><td colspan="3" class="text-center p-4">Memuat data...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Tab 3: Bank Soal -->
                    <div id="tab-soal" class="admin-tab-content hidden no-print">
                        <div class="bg-blue-50 p-4 rounded-lg mb-6 border border-blue-100">
                            <h3 class="font-bold text-blue-800 mb-3"><i class="fas fa-plus-circle"></i> Tambah Soal Baru</h3>
                            <div class="space-y-3">
                                <textarea id="new-soal-reading" rows="2" placeholder="Teks Bacaan Panjang (Opsional, kosongkan jika tidak ada)" class="w-full px-4 py-2 rounded-lg border focus:ring-2 focus:ring-blue-500"></textarea>
                                <textarea id="new-soal-question" rows="2" placeholder="Pertanyaan Ujian (Wajib)" class="w-full px-4 py-2 rounded-lg border focus:ring-2 focus:ring-blue-500"></textarea>
                                
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                    <input type="text" id="new-soal-optA" placeholder="Pilihan A" class="w-full px-4 py-2 rounded-lg border">
                                    <input type="text" id="new-soal-optB" placeholder="Pilihan B" class="w-full px-4 py-2 rounded-lg border">
                                    <input type="text" id="new-soal-optC" placeholder="Pilihan C" class="w-full px-4 py-2 rounded-lg border">
                                    <input type="text" id="new-soal-optD" placeholder="Pilihan D" class="w-full px-4 py-2 rounded-lg border">
                                </div>
                                
                                <div class="flex flex-col md:flex-row gap-3 items-center mt-2">

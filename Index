                <div class="flex-grow text-center text-gray-500 font-semibold pt-2">
                    Soal <span id="current-q-num">1</span> dari <span id="total-q-num">x</span>
                </div>
                <button onclick="nextQuestion()" id="btn-next" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-6 rounded-lg">
                    Berikutnya <i class="fas fa-arrow-right"></i>
                </button>
                <button onclick="confirmSubmit()" id="btn-submit" class="bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-6 rounded-lg hide shadow-lg">
                    Selesai & Kumpulkan <i class="fas fa-check-circle"></i>
